<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naciri Saveurs Traiteur | L'Excellence à Berrechid</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --rouge-profond: #6b0000;
            --or-prestige: #c5a059;
            --noir-mat: #1a1a1a;
            --creme: #fdfaf5;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--creme);
            margin: 0;
            color: var(--noir-mat);
        }

        /* Hero Section avec Logo */
        header {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1541529086526-db283c563270?auto=format&fit=crop&q=80&w=1000');
            background-size: cover;
            background-position: center;
            height: 60vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            border-bottom: 4px solid var(--or-prestige);
        }

        .logo-prestige {
            max-width: 250px;
            filter: drop-shadow(0 0 10px rgba(0,0,0,0.5));
            margin-bottom: 20px;
        }

        /* Galerie de Photos Réelles */
        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
            padding: 20px;
            max-width: 1200px;
            margin: -50px auto 0;
        }

        .photo-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .photo-card:hover { transform: translateY(-5px); }

        .photo-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .photo-info { padding: 15px; text-align: center; }
        .photo-info h3 { margin: 0; color: var(--rouge-profond); font-size: 1.1rem; }

        /* Section Commande */
        .order-section {
            max-width: 600px;
            margin: 40px auto;
            padding: 30px;
            background: white;
            border-radius: 20px;
            border-top: 5px solid var(--or-prestige);
        }

        .status-badge {
            background: #fff4e6;
            color: #d97706;
            padding: 8px;
            border-radius: 8px;
            text-align: center;
            font-weight: 600;
            margin-bottom: 20px;
            display: block;
        }

        .input-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: 600; }
        input, select {
            width: 100%;
            padding: 12px;
            border: 2px solid #eee;
            border-radius: 10px;
            box-sizing: border-box;
        }

        .btn-whatsapp {
            background: #25D366;
            color: white;
            padding: 18px;
            width: 100%;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }

        .footer {
            text-align: center;
            padding: 40px;
            background: var(--noir-mat);
            color: white;
        }

        /* Flottant WhatsApp */
        .wa-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #25D366;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            z-index: 1000;
        }
    </style>
</head>
<body>

<header>
    <!-- Assurez-vous que votre fichier logo s'appelle logo.png sur GitHub -->
    <img src="logo.png" alt="Naciri Saveurs Traiteur" class="logo-prestige">
    <p style="font-family: 'Playfair Display'; font-size: 1.5rem; letter-spacing: 2px;">L'ART DE LA TABLE MAROCAINE</p>
</header>

<div class="gallery">
    <div class="photo-card">
        <img src="https://images.unsplash.com/photo-1541529086526-db283c563270" alt="Tajine Prestige">
        <div class="photo-info"><h3>Tajines Gastronomiques</h3></div>
    </div>
    <div class="photo-card">
        <img src="https://images.unsplash.com/photo-1511690656952-34342bb7c2f2" alt="Pastilla Royale">
        <div class="photo-info"><h3>Pastillas d'Exception</h3></div>
    </div>
    <div class="photo-card">
        <img src="https://images.unsplash.com/photo-1505575967455-40e256f73376" alt="Traiteur Berrechid">
        <div class="photo-info"><h3>Buffets & Réceptions</h3></div>
    </div>
</div>

<div class="order-section">
    <span class="status-badge">🕰️ Ouvert du Lundi au Samedi | Fermé le Dimanche</span>
    <h2 style="text-align: center; color: var(--rouge-profond);">Réserver votre festin</h2>
    
    <div class="input-group">
        <label>Votre Nom</label>
        <input type="text" id="nom" placeholder="Nom complet">
    </div>

    <div class="input-group">
        <label>Spécialité souhaitée</label>
        <select id="plat">
            <option value="Tajine de Viande aux Pruneaux">Tajine de Viande aux Pruneaux</option>
            <option value="Pastilla Royale aux Fruits de Mer">Pastilla Royale aux Fruits de Mer</option>
            <option value="Couscous de Réception">Couscous de Réception</option>
            <option value="Assortiment de Batbouts Farcis">Assortiment de Batbouts Farcis</option>
            <option value="Dajaj Mhamer aux Olives">Dajaj Mhamer aux Olives</option>
        </select>
    </div>

    <div class="input-group">
        <label>Adresse (Berrechid, Settat, Bouskoura...)</label>
        <input type="text" id="adresse" placeholder="Quartier et Ville">
    </div>

    <button class="btn-whatsapp" onclick="sendOrder()">
        📱 COMMANDER VIA WHATSAPP
    </button>
</div>

<div class="footer">
    <p>© 2026 Naciri Saveurs Traiteur - Berrechid</p>
    <p>WhatsApp : 212 6 31 23 89 15</p>
</div>

<a href="https://wa.me/212631238915" class="wa-float" target="_blank">
    <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" width="35">
</a>

<script>
    function sendOrder() {
        const nom = document.getElementById('nom').value;
        const plat = document.getElementById('plat').value;
        const adresse = document.getElementById('adresse').value;
        const tel = "212631238915";

        if(!nom || !adresse) return alert("Merci de préciser votre nom et adresse.");

        const msg = `*NACIRI SAVEURS TRAITEUR*%0A` +
                    `--------------------------%0A` +
                    `*Nouvelle commande :*%0A` +
                    `• *Client :* ${nom}%0A` +
                    `• *Plat :* ${plat}%0A` +
                    `• *Adresse :* ${adresse}%0A` +
                    `--------------------------%0A` +
                    `_Envoyé depuis le site prestige_`;

        window.open(`https://wa.me/${tel}?text=${msg}`, '_blank');
    }
</script>

</body>
</html>
